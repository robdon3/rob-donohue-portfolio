# Copy to .env and fill as needed. Never commit real keys.

# Data source: mock | yfinance | alpha_vantage
FINANCE_PROVIDER=mock

# Alpha Vantage (free tier): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Request behavior
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_SECONDS=1.5

# Cache (seconds). 0 disables.
CACHE_TTL_SECONDS=300

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
